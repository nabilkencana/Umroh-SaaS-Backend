# Database
# Option 1: Local PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/umroh_db?schema=public"

# Option 2: Docker PostgreSQL
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/umroh_db?schema=public"

# Option 3: Supabase (Recommended for beginners)
# Get from: Supabase Dashboard > Project Settings > Database > Connection string (URI)
